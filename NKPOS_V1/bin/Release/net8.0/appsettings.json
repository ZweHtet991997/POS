{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.MSSqlServer" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "Server=nkpos.ctec6qg6a2b1.eu-north-1.rds.amazonaws.com;Database=NK_POS;User Id=nksoftware;Password=NKsoftwarehouse*11;TrustServerCertificate=True;",
          "tableName": "Logs",
          "autoCreateSqlTable": true,
          "columnOptionsSection": {
            "AdditionalColumns": [
              {
                "ColumnName": "UserName",
                "DataType": "nvarchar",
                "DataLength": 50
              },
              {
                "ColumnName": "TargetMethod",
                "DataType": "nvarchar",
                "DataLength": 50
              },
              {
                "ColumnName": "Payload",
                "DataType": "nvarchar",
                "DataLength": -1
              }
            ]
          }
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithThreadId", "WithEnvironmentName", "WithMachineName" ]
  }
}
